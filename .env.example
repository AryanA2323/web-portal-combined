# Django Settings
SECRET_KEY=your-secret-key-here
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1
 
# Database Configuration
# For PostgreSQL
DB_ENGINE=django.db.backends.postgresql
DB_NAME=incident_management_db
DB_USER=postgres
DB_PASSWORD=12345
DB_HOST=localhost
DB_PORT=5432
 
# CORS Settings
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
 
# Email Configuration
# For development (emails printed to console)
# EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
 
# For production SMTP (uncomment and configure)
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=yashdhumal90@gmail.com
EMAIL_HOST_PASSWORD=
 
DEFAULT_FROM_EMAIL=noreply@incidentmanagement.com
 
# Frontend URL (for password reset links)
FRONTEND_URL=http://localhost:3000
 
# Security Settings
EMAIL_VERIFICATION_CODE_EXPIRY_MINUTES=10
PASSWORD_RESET_TOKEN_EXPIRY_HOURS=1
 
# Gmail OAuth
GMAIL_CLIENT_ID=your_gmail_client_id
GMAIL_CLIENT_SECRET=your_gmail_client_secret

# Gemini AI
GROK_API_KEY=your_grok_api_key

# Groq API (for Speech-to-Text and AI features)
GROQ_API_KEY=your_groq_api_key

# Speech Statement Service Configuration
# Provider: groq (default) or speechmatics
SPEECH_PROVIDER=groq
# Maximum audio file size in MB (default: 15)
SPEECH_MAX_FILE_MB=15
# Maximum audio duration in seconds (default: 180)
SPEECH_MAX_DURATION_SECONDS=180
# Request timeout for speech API calls in seconds (default: 60)
SPEECH_REQUEST_TIMEOUT_SECONDS=60
# STT model (default: whisper-large-v3)
SPEECH_STT_MODEL=whisper-large-v3
# Translation model (default: llama-3.3-70b-versatile)
SPEECH_TRANSLATION_MODEL=llama-3.3-70b-versatile

# Speechmatics API (required if SPEECH_PROVIDER=speechmatics)
SPEECHMATICS_API_KEY=your_speechmatics_api_key
# SPEECHMATICS_API_URL=https://asr.api.speechmatics.com/v2
# SPEECHMATICS_POLL_INTERVAL=2
# SPEECHMATICS_MAX_POLL_ATTEMPTS=60
 
# Outlook OAuth
OUTLOOK_CLIENT_ID=your_outlook_client_id
OUTLOOK_CLIENT_SECRET=your_outlook_client_secret
OUTLOOK_TENANT_ID=common
 
# Geocoding API Keys (optional - defaults to free Nominatim service)
# Google Maps Geocoding API (faster, more accurate, requires billing)
GOOGLE_MAPS_API_KEY=your_google_maps_api_key
 
# Azure Maps API (alternative to Google)
# AZURE_MAPS_API_KEY=your_azure_maps_api_key
